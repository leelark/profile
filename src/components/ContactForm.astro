---
import { contact } from "@/lib/content";

const redirect = "https://leelark.github.io/profile/thanks/";
---

<form class="grid gap-5" action="https://splitforms.com/api/submit" method="POST">
  <input type="hidden" name="access_key" value="8897600acb7b48f09fb9d1f78895c3b6" />
  <input type="hidden" name="redirect" value={redirect} />
  <input type="hidden" name="subject" value="Portfolio inquiry for Leelark Saxena" />
  <input type="hidden" name="source" value="leelark.github.io/profile/contact" />
  <label class="hidden" aria-hidden="true">
    Leave this field empty
    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
  </label>

  <div class="grid gap-5 md:grid-cols-2">
    <label class="grid gap-2">
      <span class="text-sm font-semibold text-text">Name</span>
      <input class="min-h-12 rounded-portfolio border border-border bg-elevated px-4 text-text" name="name" autocomplete="name" required />
    </label>
    <label class="grid gap-2">
      <span class="text-sm font-semibold text-text">Email</span>
      <input class="min-h-12 rounded-portfolio border border-border bg-elevated px-4 text-text" name="email" type="email" autocomplete="email" required />
    </label>
  </div>

  <div class="grid gap-5 md:grid-cols-2">
    <label class="grid gap-2">
      <span class="text-sm font-semibold text-text">Company or organization</span>
      <input class="min-h-12 rounded-portfolio border border-border bg-elevated px-4 text-text" name="company" autocomplete="organization" />
    </label>
    <label class="grid gap-2">
      <span class="text-sm font-semibold text-text">Inquiry type</span>
      <select class="min-h-12 rounded-portfolio border border-border bg-elevated px-4 text-text" name="inquiry_type" required>
        <option value="">Select an inquiry type</option>
        {contact.inquiryTypes.map((type) => <option value={type}>{type}</option>)}
      </select>
    </label>
  </div>

  <label class="grid gap-2">
    <span class="text-sm font-semibold text-text">Message</span>
    <textarea class="min-h-40 rounded-portfolio border border-border bg-elevated px-4 py-3 text-text" name="message" required minlength="20" autocomplete="off"></textarea>
    <span class="text-xs leading-5 text-muted">Share the context, project type, or Appian challenge you want to discuss.</span>
  </label>

  <button class="inline-flex min-h-12 w-fit items-center justify-center rounded-portfolio bg-accent px-6 text-sm font-bold text-white transition hover:bg-accent/90" type="submit">
    Send message
    <span class="ml-2" aria-hidden="true">-&gt;</span>
  </button>
</form>
