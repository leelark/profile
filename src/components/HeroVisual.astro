---
import { withBase } from "@/lib/paths";
---

<div class="hero-portrait-system" aria-label="Leelark Saxena profile visual">
  <div class="hero-portrait-shell">
    <div class="hero-portrait-light hero-portrait-light-top" aria-hidden="true"></div>
    <div class="hero-portrait-light hero-portrait-light-bottom" aria-hidden="true"></div>
    <div class="hero-portrait-ring hero-portrait-ring-outer" aria-hidden="true"></div>
    <div class="hero-portrait-ring hero-portrait-ring-inner" aria-hidden="true"></div>
    <figure class="hero-portrait-frame">
      <img
        class="hero-portrait-image"
        src={withBase("/main_photo.jpg")}
        alt="Leelark Saxena"
        loading="eager"
        decoding="async"
      />
    </figure>
    <div class="hero-credential-card">
      <p class="text-[0.68rem] font-bold uppercase text-muted">Role</p>
      <p class="mt-1 text-sm font-semibold text-text">Solution Architect</p>
    </div>
    <div class="hero-focus-card">
      <p class="text-[0.68rem] font-bold uppercase text-muted">Delivery Lens</p>
      <p class="mt-1 text-sm font-semibold text-text">Enterprise Appian + AI Workflows</p>
    </div>
  </div>
</div>
