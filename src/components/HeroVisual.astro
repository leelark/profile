---
import { withBase } from "@/lib/paths";

const signals = [
  "Requirement analysis",
  "Solution design",
  "SAIL development",
  "Workflow automation",
  "Appian AI",
  "Plugin engineering"
];
---

<div class="hero-portrait-system" aria-label="Leelark Saxena profile visual">
  <div class="hero-portrait-shell">
    <div class="hero-portrait-ring hero-portrait-ring-outer" aria-hidden="true"></div>
    <div class="hero-portrait-ring hero-portrait-ring-inner" aria-hidden="true"></div>
    <figure class="hero-portrait-frame">
      <img
        class="hero-portrait-image"
        src={withBase("/main_photo.jpg")}
        alt="Leelark Saxena"
        loading="eager"
        decoding="async"
      />
    </figure>
    <div class="hero-credential-card">
      <p class="text-[0.68rem] font-bold uppercase text-muted">Certified</p>
      <p class="mt-1 text-sm font-semibold text-text">Appian Level-3 / Lead Developer</p>
    </div>
    <div class="hero-focus-card">
      <p class="text-[0.68rem] font-bold uppercase text-muted">Positioning</p>
      <p class="mt-1 text-sm font-semibold text-text">Appian Solution Architect</p>
    </div>
  </div>

  <div class="mt-6 grid gap-2 sm:grid-cols-2">
    {signals.map((signal) => (
      <span class="hero-signal-chip">{signal}</span>
    ))}
  </div>
</div>
