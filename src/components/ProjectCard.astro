---
import EvidenceBadge from "./EvidenceBadge.astro";
import type { ProjectDetail } from "@/lib/content";
import { projectPath } from "@/lib/paths";

type Props = {
  project: ProjectDetail;
  compact?: boolean;
};

const { project, compact = false } = Astro.props;
---

<article class="group flex h-full min-h-[330px] flex-col justify-between rounded-portfolio border border-border bg-surface/82 p-5 transition duration-180 hover:-translate-y-0.5 hover:border-accent/55 hover:bg-elevated/80 md:p-6">
  <div>
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span class="chip">{project.category}</span>
      <EvidenceBadge status={project.evidenceStatus} />
    </div>
    <h3 class="text-xl font-semibold leading-snug text-text">{project.title}</h3>
    <p class="mt-3 text-sm font-medium text-accent">{project.role}</p>
    <p class="mt-4 text-sm leading-7 text-muted">{project.heroExcerpt}</p>
  </div>

  <div class="mt-6">
    {!compact && (
      <div class="mb-5 flex flex-wrap gap-2">
        {project.tags.slice(0, 4).map((tag) => <span class="chip text-[0.72rem]">{tag}</span>)}
      </div>
    )}
    <a class="inline-flex min-h-11 items-center justify-center rounded-portfolio border border-border px-4 text-sm font-semibold text-text transition hover:border-accent hover:bg-accent/12" href={projectPath(project.slug)}>
      View case study
      <span class="ml-2 transition group-hover:translate-x-0.5" aria-hidden="true">-&gt;</span>
    </a>
  </div>
</article>
