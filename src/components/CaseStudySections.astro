---
import type { ProjectDetail } from "@/lib/content";

type Props = {
  project: ProjectDetail;
};

const { project } = Astro.props;
const priority = [
  "Project Context",
  "Problem",
  "My Role",
  "Solution Overview",
  "Architecture and Technical Approach",
  "Key Features",
  "UX and Product Decisions",
  "Business Value",
  "Technologies and Appian Capabilities"
];

const sections = priority
  .map((title) => project.sections.find((section) => section.title === title))
  .filter(Boolean);
---

<div class="mx-auto max-w-reading space-y-10">
  {sections.map((section) => (
    <section class="border-t border-border pt-8">
      <p class="eyebrow mb-3">{section!.title}</p>
      <div class="prose-portfolio" set:html={section!.html} />
    </section>
  ))}
</div>
