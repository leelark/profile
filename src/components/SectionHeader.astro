---
type Props = {
  eyebrow?: string;
  title: string;
  copy?: string;
  align?: "left" | "center";
  as?: "h1" | "h2";
};

const { eyebrow, title, copy, align = "left", as = "h2" } = Astro.props as Props;
const Heading = as;
---

<div class={`max-w-reading ${align === "center" ? "mx-auto text-center" : ""}`}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <Heading class="text-balance text-3xl font-semibold leading-tight text-text md:text-5xl">{title}</Heading>
  {copy && <p class="mt-5 text-pretty text-base leading-8 text-muted md:text-lg">{copy}</p>}
</div>
