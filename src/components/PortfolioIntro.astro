<script is:inline>
  (() => {
    const intro = document.querySelector("[data-portfolio-intro]");
    if (!(intro instanceof HTMLElement)) return;

    const skipButton = intro.querySelector("[data-portfolio-intro-skip]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const canUsePointer = !reduceMotion;
    const seenKey = "leelarkPortfolioIntroSeen";
    const forceIntro = new URLSearchParams(window.location.search).get("intro") === "1";
    const getSeenIntro = () => {
      try {
        return window.sessionStorage.getItem(seenKey) === "true";
      } catch {
        return false;
      }
    };
    const markSeenIntro = () => {
      try {
        window.sessionStorage.setItem(seenKey, "true");
      } catch {
        /* Keep the intro disposable when storage is unavailable. */
      }
    };
    const hasSeenIntro = getSeenIntro();

    let isFinished = false;
    let exitTimer;
    let pointerFrame;

    const setPointerVars = (x, y) => {
      intro.style.setProperty("--intro-shift-x", `${x * 24}px`);
      intro.style.setProperty("--intro-shift-y", `${y * 18}px`);
      intro.style.setProperty("--intro-shift-x-soft", `${x * 12}px`);
      intro.style.setProperty("--intro-shift-y-soft", `${y * 9}px`);
      intro.style.setProperty("--intro-shift-x-deep", `${x * -16}px`);
      intro.style.setProperty("--intro-shift-y-deep", `${y * -12}px`);
      intro.style.setProperty("--intro-rotate-x", `${y * -5.5}deg`);
      intro.style.setProperty("--intro-rotate-y", `${x * 7}deg`);
      intro.style.setProperty("--intro-focus-x", `${50 + x * 8}%`);
      intro.style.setProperty("--intro-focus-y", `${46 + y * 7}%`);
    };

    const handlePointerMove = (event) => {
      if (!canUsePointer) return;
      window.cancelAnimationFrame(pointerFrame);
      pointerFrame = window.requestAnimationFrame(() => {
        const bounds = intro.getBoundingClientRect();
        const x = ((event.clientX - bounds.left) / bounds.width) - 0.5;
        const y = ((event.clientY - bounds.top) / bounds.height) - 0.5;
        setPointerVars(x, y);
      });
    };

    const resetPointer = () => {
      if (!canUsePointer) return;
      setPointerVars(0, 0);
    };

    const handleKeydown = (event) => {
      if (event.key !== "Escape") return;
      finishIntro();
    };

    const finishIntro = () => {
      if (isFinished) return;
      isFinished = true;
      window.clearTimeout(exitTimer);
      window.cancelAnimationFrame(pointerFrame);
      window.removeEventListener("keydown", handleKeydown);
      intro.removeEventListener("pointermove", handlePointerMove);
      intro.removeEventListener("mousemove", handlePointerMove);
      intro.removeEventListener("pointerleave", resetPointer);
      intro.removeEventListener("mouseleave", resetPointer);
      intro.dataset.state = "exiting";
      document.body.removeAttribute("data-intro-lock");
      markSeenIntro();
      window.setTimeout(() => {
        intro.dataset.state = "hidden";
        intro.setAttribute("aria-hidden", "true");
      }, reduceMotion ? 120 : 620);
    };

    if (hasSeenIntro && !forceIntro) {
      intro.dataset.state = "hidden";
      intro.setAttribute("aria-hidden", "true");
      return;
    }

    document.documentElement.removeAttribute("data-skip-portfolio-intro");
    document.body.setAttribute("data-intro-lock", "true");
    intro.dataset.state = "active";

    const autoDelay = reduceMotion ? 1900 : 5800;
    let timerStarted = false;
    const startExitTimer = () => {
      if (timerStarted || isFinished) return;
      timerStarted = true;
      exitTimer = window.setTimeout(finishIntro, autoDelay);
    };

    if (reduceMotion) {
      startExitTimer();
    } else {
      const fallbackTimer = window.setTimeout(startExitTimer, 360);
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          window.clearTimeout(fallbackTimer);
          startExitTimer();
        });
      });
    }

    skipButton?.addEventListener("click", finishIntro);
    window.addEventListener("keydown", handleKeydown);
    intro.addEventListener("pointermove", handlePointerMove);
    intro.addEventListener("mousemove", handlePointerMove);
    intro.addEventListener("pointerleave", resetPointer);
    intro.addEventListener("mouseleave", resetPointer);
  })();
</script>
