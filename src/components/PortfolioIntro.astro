<script is:inline>
  (() => {
    try {
      const forceIntro = new URLSearchParams(window.location.search).get("intro") === "1";
      const hasSeenIntro = window.sessionStorage.getItem("leelarkPortfolioIntroSeen") === "true";
      if (hasSeenIntro && !forceIntro) {
        document.documentElement.setAttribute("data-skip-portfolio-intro", "true");
      }
    } catch {
      /* Show the intro when storage is unavailable. */
    }
  })();
</script>

