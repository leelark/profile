---
import type { EvidenceStatus } from "@/lib/content";

type Props = {
  status: EvidenceStatus;
};

const { status } = Astro.props;

const styles = {
  Confirmed: "border-verified/45 bg-verified/10 text-verified",
  "Partially Confirmed": "border-blueSignal/45 bg-blueSignal/10 text-blueSignal",
  "Needs Confirmation": "border-caution/50 bg-caution/10 text-caution"
};
---

<span class={`chip ${styles[status]}`} aria-label={`Evidence status: ${status}`}>
  <span aria-hidden="true">*</span>
  {status}
</span>
