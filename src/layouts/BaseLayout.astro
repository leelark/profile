---
import NavControls from "@/components/NavControls";
import { profile } from "@/lib/content";
import { canonicalUrl, withBase } from "@/lib/paths";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  path?: string;
  noindex?: boolean;
  hideIdentity?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const {
  title = "Leelark Saxena - Enterprise Appian Architect",
  description = profile.homepageSummary,
  path = "/",
  noindex = false,
  hideIdentity = false,
  structuredData
} = Astro.props;

const pageTitle = title.includes("Leelark") ? title : `${title} | Leelark Saxena`;
const canonical = canonicalUrl(path);
const socialImage = canonicalUrl("/og-image.png");
const normalizePath = (value: string) => {
  const cleaned = value === "/" ? value : value.replace(/\/$/, "");
  return cleaned || "/";
};
const currentPath = normalizePath(path);
const navLinks = [
  { path: "/", label: "Home" },
  { path: "/work", label: "Work" },
  { path: "/key-works", label: "Key Works" },
  { path: "/resume", label: "Resume" },
  { path: "/contact", label: "Contact" }
].map((link) => ({
  ...link,
  href: withBase(link.path),
  current: link.path === "/" ? currentPath === "/" : currentPath === link.path || currentPath.startsWith(`${link.path}/`)
}));
const showFloatingContact = currentPath !== "/contact";
const hideFloatingContactAtHomeCta = currentPath === "/";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Leelark Saxena Portfolio" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Leelark Saxena portfolio preview with enterprise Appian, workflow automation, plugin, and accelerator positioning." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="theme-color" content="#341539" />
    <script is:inline>
      const savedTheme = window.localStorage.getItem("theme");
      document.documentElement.dataset.theme = savedTheme === "light" ? "light" : "dark";
    </script>
    <script is:inline>
      const setHeaderState = () => {
        document.documentElement.dataset.navState = window.scrollY > 16 ? "scrolled" : "top";
      };
      setHeaderState();
      window.addEventListener("scroll", setHeaderState, { passive: true });
    </script>
    {hideFloatingContactAtHomeCta && (
      <script is:inline>
        const setFloatingContactState = () => {
          const bar = document.querySelector("[data-floating-contact]");
          const contactSection = document.querySelector("#next-conversation");
          if (!bar || !contactSection) return;

          const sectionRect = contactSection.getBoundingClientRect();
          const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
          const shouldHide = sectionRect.top < viewportHeight * 0.82 && sectionRect.bottom > viewportHeight * 0.2;
          bar.dataset.state = shouldHide ? "hidden" : "visible";
        };

        window.addEventListener("load", setFloatingContactState, { once: true });
        window.addEventListener("scroll", setFloatingContactState, { passive: true });
        window.addEventListener("resize", setFloatingContactState);
      </script>
    )}
    {structuredData && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <div class="site-background-field" aria-hidden="true">
      <span class="site-background-layer site-background-depth"></span>
      <span class="site-background-layer site-background-structure"></span>
      <span class="site-background-layer site-background-signal"></span>
    </div>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="shell site-header-shell">
        {hideIdentity ? (
          <div class="site-identity-placeholder" aria-hidden="true"></div>
        ) : (
          <a class="site-identity" href={withBase("/")}>
            <span class="site-identity-mark" aria-hidden="true">LS</span>
            <span class="site-identity-copy">
              <span>Leelark Saxena</span>
              <span>Solution Architect & Lead Appian Developer</span>
            </span>
          </a>
        )}
        <nav class="desktop-tab-nav" aria-label="Primary navigation">
          {navLinks.map((link) => (
            <a
              class:list={[
                "desktop-nav-link",
                link.current && "is-current"
              ]}
              href={link.href}
              aria-current={link.current ? "page" : undefined}
            >
              <span>{link.label}</span>
            </a>
          ))}
        </nav>
        <NavControls links={navLinks} client:load />
      </div>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    {showFloatingContact && (
      <aside class="floating-contact-bar" data-floating-contact data-state="visible" aria-label="Contact shortcut">
        <div class="floating-contact-copy">
          <span>Available for Appian architecture, AI workflow, and plugin delivery.</span>
        </div>
        <a class="floating-contact-action" href={withBase("/contact")}>
          <span>Start a conversation</span>
        </a>
      </aside>
    )}

    <footer class="border-t border-border py-10">
      <div class="shell flex flex-col gap-4 text-sm text-muted md:flex-row md:items-center md:justify-between">
        <p>Leelark Saxena - Solution Architect and Lead Appian Developer.</p>
        <div class="flex flex-wrap gap-3">
          <a class="hover:text-text" href={withBase("/work")}>Work</a>
          <a class="hover:text-text" href={withBase("/contact")}>Contact</a>
          <a class="hover:text-text" href="mailto:leelarksaxena1997@outlook.com">Email</a>
        </div>
      </div>
    </footer>
  </body>
</html>
