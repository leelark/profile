---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BadgeCheck, BriefcaseBusiness, ExternalLink, GraduationCap, Newspaper, ShieldCheck } from "lucide-react";
import { certifications, education, experience, publication } from "@/lib/content";
import { withBase } from "@/lib/paths";
import { breadcrumbStructuredData, personStructuredData, webPageStructuredData } from "@/lib/seo";
import "@/styles/resume.css";

const pageDescription =
  "Professional resume for Leelark Saxena, covering Appian work experience, education, certifications, and publication.";
const structuredData = [
  personStructuredData(),
  webPageStructuredData({
    type: "ProfilePage",
    name: "Resume - Leelark Saxena",
    description: pageDescription,
    path: "/resume"
  }),
  breadcrumbStructuredData([
    { name: "Home", path: "/" },
    { name: "Resume", path: "/resume" }
  ])
];

const resumeStats = ["6+ years", "Appian L3", "Solution Architect"];

const companyLogos: Record<string, { initials: string; logoUrl: string; logoAlt: string }> = {
  "Yexle Pvt. Limited": {
    initials: "YX",
    logoUrl: withBase("/brand/company/yexle-logo.png"),
    logoAlt: "Yexle logo"
  },
  "Coforge DPA Pvt. Limited": {
    initials: "CF",
    logoUrl: withBase("/brand/company/coforge-logo.svg"),
    logoAlt: "Coforge logo"
  },
  "Persistent Systems Ltd": {
    initials: "PS",
    logoUrl: withBase("/brand/company/persistent-logo.png"),
    logoAlt: "Persistent Systems logo"
  }
};

const credentialCards = certifications.map((item) => ({
  ...item,
  score: item.score?.replace(/^.*92%$/, "\u2248 92%")
}));
---

<BaseLayout title="Resume" description={pageDescription} path="/resume" structuredData={structuredData} hideIdentity>
  <div class="resume-page resume-page-minimal">
    <section class="resume-section resume-work-section">
      <div class="shell">
        <header class="resume-minimal-header" data-reveal="text" aria-label="Resume overview">
          <div class="resume-header-kicker">
            <span aria-hidden="true"></span>
            <p>Experience / Education</p>
          </div>
          <div class="resume-metric-strip" aria-label="Resume snapshot">
            {resumeStats.map((stat) => (
              <span>{stat}</span>
            ))}
          </div>
        </header>

        <div class="resume-section-title" data-reveal="text" style="--reveal-delay: 70ms">
          <span aria-hidden="true"><BriefcaseBusiness size={18} strokeWidth={2.2} /></span>
          <h1>Experience</h1>
        </div>

        <div class="resume-experience-stream" data-reveal-group style="--reveal-delay: 120ms" aria-label="Work experience timeline">
          {experience.map((item, index) => {
            const companyLogo = companyLogos[item.company] ?? {
              initials: item.company.slice(0, 2).toUpperCase(),
              logoUrl: "",
              logoAlt: `${item.company} logo`
            };

            return (
              <article class="resume-experience-row" style={`--row-index: ${index}`}>
                <div class="resume-experience-index" aria-hidden="true">
                  <span></span>
                </div>
                <div class="resume-experience-main">
                  <span class="resume-company-mark">
                    {companyLogo.logoUrl && (
                      <img
                        src={companyLogo.logoUrl}
                        alt={companyLogo.logoAlt}
                        loading="lazy"
                        decoding="async"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';"
                      />
                    )}
                    <b class:list={["resume-company-fallback", companyLogo.logoUrl && "resume-company-fallback-hidden"]}>
                      {companyLogo.initials}
                    </b>
                  </span>
                  <div>
                    <h2>{item.role}</h2>
                    <p>{item.company}</p>
                  </div>
                </div>
                <time>{item.period}</time>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="resume-section resume-education-section border-t border-border">
      <div class="shell">
        <div class="resume-section-title" data-reveal="text">
          <span aria-hidden="true"><GraduationCap size={18} strokeWidth={2.2} /></span>
          <h2>Education</h2>
        </div>

        <div class="resume-education-arc" data-reveal="section" style="--reveal-delay: 70ms" aria-label="Education details">
          <div class="resume-education-core" aria-hidden="true">
            <GraduationCap size={30} strokeWidth={2.1} />
            <strong>CS</strong>
          </div>
          <div class="resume-education-lane" data-reveal-group style="--reveal-delay: 120ms">
            {education.map((item, index) => (
              <article class="resume-education-item" style={`--education-index: ${index}`}>
                <div class="resume-education-node" aria-hidden="true">
                  <span>{item.year}</span>
                </div>
                <div class="resume-education-card">
                  <h3>{item.qualification}</h3>
                  <p>{item.institution}</p>
                  {item.score && <strong>{item.score}</strong>}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="resume-section resume-credential-section border-t border-border">
      <div class="shell">
        <div class="resume-section-title" data-reveal="text">
          <span aria-hidden="true"><BadgeCheck size={18} strokeWidth={2.2} /></span>
          <h2>Credentials</h2>
        </div>

        <div class="resume-credential-layout" data-reveal-group style="--reveal-delay: 90ms">
          <article class="resume-certification-ribbon">
            <h3>Certifications</h3>
            <div>
              {credentialCards.map((item) => (
                <span>
                  <i aria-hidden="true"><ShieldCheck size={15} strokeWidth={2.3} /></i>
                  <strong>{item.title}</strong>
                  {item.score && <small>{item.score}</small>}
                </span>
              ))}
            </div>
          </article>

          <article class="resume-publication-panel">
            <span aria-hidden="true"><Newspaper size={20} strokeWidth={2.2} /></span>
            <div>
              <h3>Research Publication</h3>
              <p class="resume-publication-title">{publication.title}</p>
              <p class="resume-publication-note">{publication.publicNote}</p>
              <a href={publication.url} target="_blank" rel="noreferrer">
                View publication
                <ExternalLink size={14} strokeWidth={2.2} aria-hidden="true" />
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
