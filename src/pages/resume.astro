---
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { certifications, education, experience, publication } from "@/lib/content";
import { breadcrumbStructuredData, personStructuredData, webPageStructuredData } from "@/lib/seo";

const pageDescription = "Compact professional resume for Leelark Saxena, Appian Solution Architect and Developer.";
const structuredData = [
  personStructuredData(),
  webPageStructuredData({
    type: "ProfilePage",
    name: "Resume - Leelark Saxena",
    description: pageDescription,
    path: "/resume"
  }),
  breadcrumbStructuredData([
    { name: "Home", path: "/" },
    { name: "Resume", path: "/resume" }
  ])
];
---

<BaseLayout title="Resume" description={pageDescription} path="/resume" structuredData={structuredData}>
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Resume" title="Enterprise Appian delivery experience, built for quick recruiter review." copy="A concise view of consulting roles, Appian delivery depth, education, certifications, and research foundation." />

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="proof-tile">
          <dt>Experience</dt>
          <dd>6+ years</dd>
        </div>
        <div class="proof-tile">
          <dt>Certification</dt>
          <dd>Appian L3</dd>
        </div>
        <div class="proof-tile">
          <dt>Role</dt>
          <dd>Solution Architect</dd>
        </div>
      </div>

      <div class="resume-journey mt-10">
        {experience.map((item, index) => (
          <article class="resume-journey-node">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h2>{item.company}</h2>
              <p>{item.role}</p>
            </div>
            <strong>{item.period}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Education" title="Academic foundation across engineering, higher secondary, and secondary education." />
      <div class="education-track mt-8">
        {education.map((item, index) => (
          <article class="education-card">
            <span class="education-step">{index + 1}</span>
            <div>
              <h2>{item.qualification}</h2>
              <p>{item.institution}</p>
              <strong>{item.year} / {item.score}</strong>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell grid gap-4 lg:grid-cols-2">
      <article class="purple-frame rounded-portfolio p-5">
        <h2 class="text-xl font-semibold text-text">Certifications</h2>
        <p class="mt-4 text-base font-semibold text-text">Appian Certified Lead Developer / Level 3</p>
        <div class="mt-4 grid gap-2">
          {certifications.slice(1).map((item) => (
            <div class="rounded-portfolio border border-border bg-surface/58 p-3">
              <p class="text-sm font-semibold text-text">{item.title}</p>
              {item.score && <p class="mt-1 text-xs font-bold text-accent">{item.score}</p>}
            </div>
          ))}
        </div>
      </article>

      <article class="purple-frame rounded-portfolio p-5">
        <h2 class="text-xl font-semibold text-text">Publication</h2>
        <p class="mt-4 text-sm font-semibold leading-6 text-text">{publication.title}</p>
        <p class="mt-3 text-sm leading-6 text-muted">{publication.websiteCopy}</p>
        <p class="mt-3 text-xs font-semibold leading-5 text-muted">{publication.publicNote}</p>
        <a class="publication-link mt-5" href={publication.url} target="_blank" rel="noreferrer">View publication</a>
      </article>
    </div>
  </section>
</BaseLayout>
