---
import HeroVisual from "@/components/HeroVisual.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TechnicalSkillGrid from "@/components/TechnicalSkillGrid";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  appianCapabilityShowcase,
  certifications,
  clientShowcase,
  experience,
  publication,
  technicalSkillGroups
} from "@/lib/content";
import { withBase } from "@/lib/paths";
import { personStructuredData, websiteStructuredData } from "@/lib/seo";

const structuredData = [personStructuredData(), websiteStructuredData()];

const heroSummary =
  "Enterprise Appian Solution Architect designing governed workflow platforms, AI-assisted orchestration, integrations, and delivery models for complex business operations.";
const heroSignals = ["Solution Architecture", "Enterprise Appian Platforms", "AI-Driven Workflows", "Appian Accelerate Program"];
const automationFlows = [
  {
    title: "Approvals",
    path: ["intake", "rules", "decision", "audit"]
  },
  {
    title: "Claims",
    path: ["evidence", "AI triage", "routing", "review"]
  },
  {
    title: "Documents",
    path: ["extract", "classify", "validate", "store"]
  },
  {
    title: "Exceptions",
    path: ["detect", "escalate", "resolve", "learn"]
  },
  {
    title: "Operations",
    path: ["monitor", "measure", "optimize", "scale"]
  }
];
const operatingLayers = [
  { title: "Impact Framing", items: ["goals", "risk", "value"], tone: "blue" },
  { title: "Co-Creation", items: ["users", "prototype", "feedback"], tone: "purple" },
  { title: "Appian Build", items: ["SAIL", "records", "process"], tone: "green" },
  { title: "AI + Integration", items: ["skills", "agents", "APIs"], tone: "amber" },
  { title: "Readiness Review", items: ["standards", "quality", "release"], tone: "blue" },
  { title: "Operate + Improve", items: ["logs", "metrics", "governance"], tone: "neutral" }
];
const domainCards = [
  { title: "Banking", code: "BK", focus: ["Regulatory workflow", "Auditability"] },
  { title: "Investment Management", code: "IM", focus: ["AML", "Reconciliation"] },
  { title: "Insurance", code: "IN", focus: ["Claims", "Evidence review"] },
  { title: "Healthcare", code: "HC", focus: ["Documents", "Revenue cycle"] },
  { title: "Manufacturing", code: "MF", focus: ["Traceability", "Exceptions"] },
  { title: "Enterprise Advisory", code: "EA", focus: ["Governance", "Platform health"] },
  { title: "Public-Sector POCs", code: "PS", focus: ["Citizen journeys", "Eligibility"] }
];
---

<BaseLayout title="Leelark Saxena - Appian Solution Architect and Developer" description={heroSummary} path="/" structuredData={structuredData}>
  <section class="section-band hero-section pt-10 md:pt-14">
    <div class="shell grid gap-9 lg:grid-cols-[1.12fr_0.88fr] lg:items-center">
      <div class="max-w-3xl reveal-up">
        <p class="eyebrow mb-4">Enterprise Appian Architecture</p>
        <h1 class="text-balance text-4xl font-semibold leading-[1.04] text-text md:text-6xl">
          Leelark Saxena
        </h1>
        <p class="mt-5 text-balance text-2xl font-semibold leading-tight text-text/94 md:text-3xl">
          Solution Architect for enterprise Appian platforms and intelligent workflow automation.
        </p>
        <p class="mt-6 max-w-2xl text-base leading-8 text-muted md:text-lg">
          {heroSummary}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="primary-button" href={withBase("/work")}>Explore work</a>
          <a class="quiet-button" href={withBase("/contact")}>Start a conversation</a>
        </div>
        <div class="hero-proof-ribbon mt-8" aria-label="Portfolio focus areas">
          {heroSignals.map((signal) => <span>{signal}</span>)}
        </div>
      </div>
      <div class="reveal-up reveal-delay-2">
        <HeroVisual />
      </div>
    </div>
  </section>

  <section class="section-band workflow-intelligence-section border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Intelligent workflow automation" title="AI-assisted orchestration for approvals, claims, documents, exceptions, and operations." copy="The portfolio centers on workflows where Appian coordinates people, records, decisions, integrations, and AI support inside governed enterprise processes." />
      <div class="workflow-river mt-9" aria-label="Intelligent workflow automation map">
        {automationFlows.map((item, index) => (
          <article class="workflow-river-node">
            <div class="workflow-river-medallion">{String(index + 1).padStart(2, "0")}</div>
            <h2>{item.title}</h2>
            <div>
              {item.path.map((step) => <span>{step}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div>
        <SectionHeader eyebrow="Appian operating model" title="From impact framing to governed operation." copy="The model reflects Appian delivery principles: fast value delivery, design for impact, co-creation, user-centered design, lightweight readiness checks, and governance through program ownership and architecture review." />
      </div>
      <div class="operating-model mt-9">
        <div class="operating-model-rail" aria-hidden="true">
          <span>01</span>
          <span>02</span>
          <span>03</span>
          <span>04</span>
          <span>05</span>
          <span>06</span>
        </div>
        <div class="operating-model-grid">
          {operatingLayers.map((layer) => (
            <article class:list={["operating-layer", `operating-layer-${layer.tone}`]}>
              <h2>{layer.title}</h2>
              <div>
                {layer.items.map((item) => <span>{item}</span>)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div>
        <SectionHeader eyebrow="Technical skills" title="Technology depth with a focused Appian capability layer." />
        <div class="mt-8">
          <TechnicalSkillGrid groups={technicalSkillGroups} appianCapabilities={appianCapabilityShowcase} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-band credential-section border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Credentials" title="Certification and research foundation." />
      <div class="credential-stage mt-8">
        <article class="credential-card credential-card-certifications">
          <h2 class="text-xl font-semibold text-text">Certifications</h2>
          <div class="mt-4 space-y-3">
            {certifications.map((item) => (
              <div class="credential-row">
                <p class="text-sm font-semibold text-text">{item.title}</p>
                {item.score && <p class="mt-1 text-xs font-bold text-accent">{item.score}</p>}
              </div>
            ))}
          </div>
        </article>
        <article class="credential-card credential-card-publication">
          <h2 class="text-xl font-semibold text-text">Research Publication</h2>
          <p class="mt-4 text-sm font-semibold leading-6 text-text">{publication.title}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{publication.websiteCopy}</p>
          <p class="mt-3 text-xs font-semibold leading-5 text-muted">{publication.publicNote}</p>
          <a class="publication-link mt-5" href={publication.url} target="_blank" rel="noreferrer">
            View publication
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Domains" title="Enterprise contexts where the Appian delivery model applies." />
      <div class="domain-constellation mt-8">
        {domainCards.map((domain) => (
          <article class="domain-card">
            <span>{domain.code}</span>
            <h2>{domain.title}</h2>
            <div>
              {domain.focus.map((item) => <i>{item}</i>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band client-showcase-section border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Client showcase" title="Enterprise names across banking, investment, advisory, and transformation programs." />
      <div class="client-marquee mt-8" aria-label="Client showcase">
        <div>
          {[...clientShowcase, ...clientShowcase].map((client) => <span>{client}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section-band career-journey-section border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Career journey" title="A concise architecture-led progression." />
      <div class="career-journey mt-8">
        {experience.map((item, index) => (
          <article class="career-node">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h2>{item.company}</h2>
            <p>{item.role}</p>
            <strong>{item.period}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div class="contact-cta-band">
        <p class="eyebrow">Next conversation</p>
        <h2>Need a Solution Architect for Appian delivery, AI workflows, or Appian Accelerate work?</h2>
        <a class="primary-button" href={withBase("/contact")}>Contact Leelark</a>
      </div>
    </div>
  </section>
</BaseLayout>
