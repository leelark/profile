---
import HeroVisual from "@/components/HeroVisual.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TechnicalSkillGrid from "@/components/TechnicalSkillGrid";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { certifications, publication, technicalSkillGroups } from "@/lib/content";
import { withBase } from "@/lib/paths";
import { personStructuredData, websiteStructuredData } from "@/lib/seo";

const structuredData = [personStructuredData(), websiteStructuredData()];

const heroSummary =
  "Enterprise Appian Solution Architect and Certified Lead Developer designing workflow platforms, data models, integrations, custom plugins, and AI-assisted experiences where they create clear business value.";
const whatIDo = [
  {
    title: "Solution Design",
    copy: "Clear requirements, process boundaries, data structures, user roles, and delivery priorities before build starts."
  },
  {
    title: "Workflow Automation",
    copy: "Reliable Appian workflows for approvals, claims, documents, exceptions, escalations, and operational handoffs."
  },
  {
    title: "Plugin Engineering",
    copy: "Custom SAIL component plugins and smart service plugin thinking for use cases that need Appian extension."
  },
  {
    title: "Platform Governance",
    copy: "Reusable accelerators, performance reviews, deployment guidance, and standards that help teams scale safely."
  }
];
const operatingLayers = [
  { title: "Business Intake", items: ["process goals", "users", "rules"], tone: "blue" },
  { title: "Appian Experience", items: ["SAIL", "records", "reports"], tone: "purple" },
  { title: "Process Orchestration", items: ["tasks", "routing", "exceptions"], tone: "green" },
  { title: "Data and Integration", items: ["data modeling", "SQL", "APIs / SFTP"], tone: "blue" },
  { title: "Extension Layer", items: ["custom SAIL plugin", "smart service plugin", "AI when useful"], tone: "amber" },
  { title: "Governance", items: ["testing", "performance", "deployment"], tone: "neutral" }
];
const domainCards = [
  { title: "Banking", copy: "Regulatory workflow, alert triage, auditability, and platform modernization." },
  { title: "Investment Management", copy: "AML, change management, reconciliation, and operational reporting." },
  { title: "Insurance", copy: "Claims intake, routing, evidence review, and decision-support flows." },
  { title: "Healthcare", copy: "Revenue-cycle and document-heavy workflow automation concepts." },
  { title: "Manufacturing", copy: "Traceability, operational records, and exception handling." },
  { title: "Enterprise Advisory", copy: "Platform health, governance, performance, and reusable accelerator guidance." },
  { title: "Public-Sector POCs", copy: "Citizen-service style journeys, document handling, and eligibility review." }
];
---

<BaseLayout title="Leelark Saxena - Appian Solution Architect and Developer" description={heroSummary} path="/" structuredData={structuredData}>
  <section class="section-band hero-section pt-10 md:pt-14">
    <div class="shell grid gap-9 lg:grid-cols-[1.12fr_0.88fr] lg:items-center">
      <div class="max-w-3xl reveal-up">
        <p class="eyebrow mb-4">Appian Solution Architect / Level-3 Certified BPM Developer</p>
        <h1 class="text-balance text-4xl font-semibold leading-[1.04] text-text md:text-6xl">
          Leelark Saxena
        </h1>
        <p class="mt-5 text-balance text-2xl font-semibold leading-tight text-text/94 md:text-3xl">
          I design Appian platforms that make enterprise workflows clearer, faster, and easier to operate.
        </p>
        <p class="mt-6 max-w-2xl text-base leading-8 text-muted md:text-lg">
          {heroSummary} The work spans solution design, hands-on build, reusable accelerators, and practical governance for regulated business operations.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="primary-button" href={withBase("/work")}>Explore work</a>
          <a class="quiet-button" href={withBase("/contact")}>Start a conversation</a>
        </div>
        <dl class="mt-8 grid gap-3 sm:grid-cols-3">
          <div class="proof-tile">
            <dt>Certification</dt>
            <dd>Appian L3</dd>
          </div>
          <div class="proof-tile">
            <dt>Core Focus</dt>
            <dd>Solution Design</dd>
          </div>
          <div class="proof-tile">
            <dt>Depth</dt>
            <dd>Plugins and AI</dd>
          </div>
        </dl>
      </div>
      <div class="reveal-up reveal-delay-2">
        <HeroVisual />
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="What I do" title="Practical Appian delivery across design, build, automation, and governance." />
      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {whatIDo.map((item, index) => (
          <article class="capability-card p-5">
            <p class="text-xs font-bold uppercase text-accent">0{index + 1}</p>
            <h2 class="mt-4 text-xl font-semibold text-text">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 text-muted">{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div>
        <SectionHeader eyebrow="Appian operating model" title="A complete delivery model for workflow, data, integration, plugins, and governance." copy="Appian is strongest when process, data, user experience, integrations, and controls are designed together. AI belongs inside that model when it improves decisions, document handling, or knowledge discovery." />
      </div>
      <div class="operating-model mt-9">
        <div class="operating-model-rail" aria-hidden="true">
          <span>01</span>
          <span>02</span>
          <span>03</span>
          <span>04</span>
          <span>05</span>
          <span>06</span>
        </div>
        <div class="operating-model-grid">
          {operatingLayers.map((layer) => (
            <article class:list={["operating-layer", `operating-layer-${layer.tone}`]}>
              <h2>{layer.title}</h2>
              <div>
                {layer.items.map((item) => <span>{item}</span>)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div>
        <SectionHeader eyebrow="Technical skills" title="A full-stack Appian skill set without raw object inventory." copy="The skill map groups the platform, programming, data, integration, and delivery capabilities that show up across the portfolio." />
        <div class="mt-8">
          <TechnicalSkillGrid groups={technicalSkillGroups} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Credentials" title="Certification and research foundation." />
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <article class="glass-panel p-5">
          <h2 class="text-xl font-semibold text-text">Certifications</h2>
          <div class="mt-4 space-y-3">
            {certifications.map((item) => (
              <div class="rounded-portfolio border border-border bg-elevated/60 p-3">
                <p class="text-sm font-semibold text-text">{item.title}</p>
                {item.score && <p class="mt-1 text-xs font-bold text-accent">{item.score}</p>}
              </div>
            ))}
          </div>
        </article>
        <article class="glass-panel p-5">
          <h2 class="text-xl font-semibold text-text">Research Publication</h2>
          <p class="mt-4 text-sm font-semibold leading-6 text-text">{publication.title}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{publication.websiteCopy}</p>
          <p class="mt-3 text-xs font-semibold leading-5 text-muted">{publication.publicNote}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Domains" title="Enterprise contexts where the Appian delivery model applies." />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {domainCards.map((domain) => (
          <article class="domain-card">
            <h2>{domain.title}</h2>
            <p>{domain.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
