---
import HeroVisual from "@/components/HeroVisual.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TechnicalSkillGrid from "@/components/TechnicalSkillGrid";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  appianCapabilityShowcase,
  certifications,
  clientShowcase,
  publication,
  technicalSkillGroups
} from "@/lib/content";
import { withBase } from "@/lib/paths";
import { personStructuredData, websiteStructuredData } from "@/lib/seo";

const structuredData = [personStructuredData(), websiteStructuredData()];

const heroSummary =
  "I lead requirements analysis, solution design, Appian delivery, AI-assisted workflow design, and integrations that connect people, data, records, documents, and enterprise systems.";
const operatingLayers = [
  {
    step: "01",
    title: "Requirements Discovery",
    copy: "Clarify business goals, user journeys, data ownership, exception paths, risk, and release constraints before Appian build begins.",
    signal: "Delivery-ready backlog",
    tone: "blue"
  },
  {
    step: "02",
    title: "Solution Architecture",
    copy: "Shape the Appian application model across records, process models, SAIL interfaces, integrations, security, and reusable patterns.",
    signal: "Architecture blueprint",
    tone: "purple"
  },
  {
    step: "03",
    title: "Lead Appian Build",
    copy: "Guide implementation with standards for interfaces, data models, expression rules, process orchestration, plugins, testing, and code quality.",
    signal: "Governed delivery",
    tone: "green"
  },
  {
    step: "04",
    title: "AI and Integration Design",
    copy: "Embed AI-assisted workflow support, document intelligence, decision support, APIs, service exposure, and operational data flows where they add value.",
    signal: "Connected automation",
    tone: "amber"
  },
  {
    step: "05",
    title: "Validation and Readiness",
    copy: "Review user experience, performance, logs, dependencies, release readiness, production risk, and support handover before rollout.",
    signal: "Release confidence",
    tone: "blue"
  },
  {
    step: "06",
    title: "Operate and Improve",
    copy: "Use platform health, metrics, feedback, governance review, and accelerator reuse to improve Appian delivery after launch.",
    signal: "Continuous improvement",
    tone: "neutral"
  }
];
const clientCards = clientShowcase.map((client) => {
  const metadata: Record<string, { initials: string; sector: string; focus: string }> = {
    Invesco: { initials: "IV", sector: "Investment management", focus: "AML, reconciliation, change delivery" },
    Carlyle: { initials: "CL", sector: "Alternative investments", focus: "Bridge module and workflow delivery" },
    HSBC: { initials: "HS", sector: "Banking", focus: "Horizon scanning and regulatory workflows" },
    KPMG: { initials: "KP", sector: "Advisory", focus: "Enterprise transformation programs" },
    EBRD: { initials: "EB", sector: "Development finance", focus: "ASB modernization and delivery support" },
    Genpact: { initials: "GP", sector: "Digital operations", focus: "Workflow modernization and automation" }
  };

  return {
    name: client,
    ...(metadata[client] ?? { initials: client.slice(0, 2).toUpperCase(), sector: "Enterprise", focus: "Appian delivery" })
  };
});
const domainCards = [
  { title: "Banking", code: "BK", focus: ["Regulatory workflow", "Auditability"] },
  { title: "Investment Management", code: "IM", focus: ["AML", "Reconciliation"] },
  { title: "Insurance", code: "IN", focus: ["Claims", "Evidence review"] },
  { title: "Healthcare", code: "HC", focus: ["Documents", "Revenue cycle"] },
  { title: "Manufacturing", code: "MF", focus: ["Traceability", "Exceptions"] },
  { title: "Enterprise Advisory", code: "EA", focus: ["Governance", "Platform health"] },
  { title: "Public-Sector POCs", code: "PS", focus: ["Citizen journeys", "Eligibility"] }
];
---

<BaseLayout title="Leelark Saxena - Appian Solution Architect and Developer" description={heroSummary} path="/" structuredData={structuredData}>
  <section class="section-band hero-section pt-10 md:pt-14">
    <div class="shell grid gap-9 lg:grid-cols-[1.12fr_0.88fr] lg:items-center">
      <div class="max-w-3xl reveal-up">
        <p class="eyebrow mb-4">Enterprise Appian Architecture</p>
        <h1 class="text-balance text-4xl font-semibold leading-[1.04] text-text md:text-6xl">
          Leelark Saxena
        </h1>
        <p class="mt-5 text-balance text-2xl font-semibold leading-tight text-text/94 md:text-3xl">
          Solution Architect and Lead Appian Developer for enterprise Appian delivery, AI-assisted workflows, and integration-led platforms.
        </p>
        <p class="mt-6 max-w-2xl text-base leading-8 text-muted md:text-lg">
          {heroSummary}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="primary-button" href={withBase("/work")}>Explore work</a>
          <a class="quiet-button" href={withBase("/contact")}>Start a conversation</a>
        </div>
      </div>
      <div class="reveal-up reveal-delay-2">
        <HeroVisual />
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div>
        <SectionHeader eyebrow="Appian delivery model" title="From requirements analysis to governed Appian operation." copy="A practical operating model for Appian programs: understand the requirement, design the solution, lead the build, connect AI and integrations, validate readiness, and improve after launch." />
      </div>
      <div class="operating-model mt-9">
        <div class="operating-model-summary">
          <span aria-hidden="true">APN</span>
          <div>
            <h2>Architecture-led delivery for Appian teams</h2>
            <p>Each stage keeps business value, user experience, data design, workflow governance, and platform reliability connected.</p>
          </div>
        </div>
        <div class="operating-model-grid">
          {operatingLayers.map((layer) => (
            <article class:list={["operating-layer", `operating-layer-${layer.tone}`]}>
              <span class="operating-step">{layer.step}</span>
              <h2>{layer.title}</h2>
              <p>{layer.copy}</p>
              <strong>{layer.signal}</strong>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div>
        <SectionHeader eyebrow="Technical skills" title="Appian-first technical depth for architecture, delivery, AI, and integrations." copy="The skill set is organized around what Appian delivery needs in practice: platform design, lead development, data modeling, APIs, AI-assisted workflows, testing, governance, and reusable accelerators." />
        <div class="mt-8">
          <TechnicalSkillGrid groups={technicalSkillGroups} appianCapabilities={appianCapabilityShowcase} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-band credential-section border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Credentials" title="Certification and research foundation." />
      <div class="credential-stage mt-8">
        <article class="credential-card credential-card-certifications">
          <h2 class="text-xl font-semibold text-text">Certifications</h2>
          <div class="mt-4 space-y-3">
            {certifications.map((item) => (
              <div class="credential-row">
                <p class="text-sm font-semibold text-text">{item.title}</p>
                {item.score && <p class="mt-1 text-xs font-bold text-accent">{item.score}</p>}
              </div>
            ))}
          </div>
        </article>
        <article class="credential-card credential-card-publication">
          <h2 class="text-xl font-semibold text-text">Research Publication</h2>
          <p class="mt-4 text-sm font-semibold leading-6 text-text">{publication.title}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{publication.websiteCopy}</p>
          <p class="mt-3 text-xs font-semibold leading-5 text-muted">{publication.publicNote}</p>
          <a class="publication-link mt-5" href={publication.url} target="_blank" rel="noreferrer">
            View publication
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Domains" title="Enterprise contexts where the Appian delivery model applies." />
      <div class="domain-constellation mt-8">
        {domainCards.map((domain) => (
          <article class="domain-card">
            <span>{domain.code}</span>
            <h2>{domain.title}</h2>
            <div>
              {domain.focus.map((item) => <i>{item}</i>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band client-showcase-section border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Enterprise delivery footprint" title="Appian delivery exposure across regulated clients, advisory programs, and transformation teams." copy="A public-safe client and program view, presented as portfolio context rather than confidential delivery detail." />
      <div class="client-marquee mt-8" aria-label="Enterprise delivery footprint">
        <div>
          {[...clientCards, ...clientCards].map((client) => (
            <article>
              <span aria-hidden="true">{client.initials}</span>
              <div>
                <h2>{client.name}</h2>
                <p>{client.sector}</p>
                <strong>{client.focus}</strong>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div class="contact-cta-band">
        <div>
          <p class="eyebrow">Next conversation</p>
          <h2>Need a Solution Architect for Appian delivery, AI workflows, or Appian Accelerate work?</h2>
          <p>Bring me in for requirements analysis, Appian solution design, lead development, AI-assisted workflow discovery, integration architecture, or delivery governance.</p>
        </div>
        <div class="contact-cta-actions">
          <span>Architecture review</span>
          <span>Appian delivery</span>
          <span>AI workflow design</span>
          <a class="primary-button" href={withBase("/contact")}>Contact Leelark</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
