---
import HeroVisual from "@/components/HeroVisual.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { expertiseAreas, featuredProjects, profile, stats } from "@/lib/content";
import { withBase } from "@/lib/paths";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: profile.name,
    jobTitle: "Enterprise Appian Solution Architect",
    url: "https://leelark.github.io/profile/",
    email: "mailto:leelarksaxena1997@outlook.com",
    knowsAbout: ["Appian", "AI workflow automation", "Enterprise architecture", "Plugin development"]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Leelark Saxena Portfolio",
    url: "https://leelark.github.io/profile/"
  }
];
---

<BaseLayout title="Leelark Saxena - Enterprise Appian Architect" description={profile.homepageSummary} path="/" structuredData={structuredData}>
  <section class="section-band">
    <div class="shell grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <p class="eyebrow mb-4">Appian architecture / AI workflows / Enterprise automation</p>
        <h1 class="max-w-4xl text-balance text-4xl font-semibold leading-[1.06] text-text md:text-6xl">
          Enterprise Appian architect building AI-powered workflows, plugins, and reusable automation platforms.
        </h1>
        <p class="mt-6 max-w-3xl text-pretty text-lg leading-8 text-muted">
          {profile.homepageSummary}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="inline-flex min-h-12 items-center rounded-portfolio bg-accent px-5 text-sm font-bold text-white transition hover:bg-accent/90" href={withBase("/work")}>
            View work
          </a>
          <a class="inline-flex min-h-12 items-center rounded-portfolio border border-border px-5 text-sm font-bold text-text transition hover:border-accent" href={withBase("/contact")}>
            Contact
          </a>
        </div>
        <dl class="mt-10 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
          {stats.map((stat) => (
            <div class="rounded-portfolio border border-border bg-surface p-4">
              <dt class="text-xs font-semibold uppercase text-muted">{stat.label}</dt>
              <dd class="mt-2 text-xl font-semibold text-text">{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>
      <HeroVisual />
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Selected work" title="Case studies that show architecture, product thinking, and Appian depth." copy="Featured work spans AI claims intelligence, knowledge discovery, Appian Accelerate advisory, EBRD workflow modernization, document intelligence plugins, and platform performance accelerators." />
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Expertise" title="A portfolio built around enterprise delivery, not isolated code samples." />
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {expertiseAreas.map((area) => (
          <article class="rounded-portfolio border border-border bg-surface p-6">
            <h3 class="text-xl font-semibold text-text">{area.title}</h3>
            <p class="mt-4 text-sm leading-7 text-muted">{area.summary}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {area.capabilities.slice(0, 5).map((capability) => <span class="chip text-[0.72rem]">{capability}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
