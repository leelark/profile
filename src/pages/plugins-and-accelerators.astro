---
import ProjectExplorer from "@/components/ProjectExplorer";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  acceleratorSuiteProjects,
  categoryLabels,
  portfolioProjectsByCategory,
  projectToCard,
  projects,
  standaloneAccelerators
} from "@/lib/content";
import type { ProjectDetail } from "@/lib/content";
import { withBase } from "@/lib/paths";
import { collectionPageStructuredData } from "@/lib/seo";

const categories = Object.entries(categoryLabels).map(([slug, label]) => ({ slug, label }));
const pluginCards = portfolioProjectsByCategory.plugins.map(projectToCard);
const standaloneAcceleratorCards = standaloneAccelerators.map(projectToCard);
const appianAccelerate = projects.find((project) => project.slug === "appian-accelerate-program");
const pageDescription =
  "Reusable Appian plugins, component patterns, and accelerator workstreams for workflow automation, document intelligence, integration, and platform governance.";
const structuredData = collectionPageStructuredData({
  name: "Plugins and Accelerators - Leelark Saxena",
  description: pageDescription,
  path: "/plugins-and-accelerators",
  projects: [...portfolioProjectsByCategory.plugins, ...(appianAccelerate ? [appianAccelerate] : []), ...standaloneAccelerators],
  breadcrumbs: [
    { name: "Home", path: "/" },
    { name: "Plugins and Accelerators", path: "/plugins-and-accelerators" }
  ]
});
const acceleratorWorkstreams = [...standaloneAccelerators, ...acceleratorSuiteProjects];
const isProject = (project: ProjectDetail | undefined): project is ProjectDetail => Boolean(project);
const acceleratorGroups = [
  {
    title: "Enterprise UX and Data Entry",
    copy: "Grid, paragraph, and hierarchical data-entry patterns for denser Appian workflows.",
    slugs: ["dynamic-editable-grid-accelerator", "editable-paragraph-grid-accelerator", "hierarchical-data-entry-ux-redesign"]
  },
  {
    title: "Excel, Document, and File Automation",
    copy: "Reusable patterns for imports, exports, document merge integrity, and viewer compatibility.",
    slugs: ["formatted-excel-import-export", "excel-merge-large-export", "document-merge-integrity-rca", "pdf-reconciliation-viewer-compatibility-rca"]
  },
  {
    title: "Platform Health, Observability, and Performance",
    copy: "Health-check, observability, and triage assets for Appian platform reliability reviews.",
    slugs: ["appian-server-metrics-performance-triage", "appian-monitoring-observability-accelerator", "appian-health-check-risk-review"]
  },
  {
    title: "Integration and Security",
    copy: "Connectivity, message queue, notification, telemetry, and SQL portability workstreams.",
    slugs: [
      "secure-snowflake-connectivity-accelerator",
      "message-queue-consumption-modernization",
      "transaction-manager-sql-portability-accelerator",
      "notification-api-reliability-accelerator",
      "device-access-audit-accelerator"
    ]
  },
  {
    title: "Governance, Deployment, and Operating Model",
    copy: "Dependency review, deployment governance, cloud operating model, and best-practice advisory assets.",
    slugs: [
      "appian-dependency-governance-accelerator",
      "appian-deployment-devops-governance",
      "appian-cloud-operating-model-advisory",
      "appian-best-practices-governance-review"
    ]
  },
  {
    title: "AI, Process Intelligence, and Transition Automation",
    copy: "AI enablement, process intelligence readiness, chatbot improvement, and transition automation patterns.",
    slugs: [
      "appian-ai-document-intelligence-enablement",
      "process-hq-readiness-accelerator",
      "enterprise-document-chatbot-improvement-accelerator",
      "autonomous-client-transition-knowledge-absorption"
    ]
  }
].map((group) => ({
  ...group,
  items: group.slugs.map((slug) => acceleratorWorkstreams.find((project) => project.slug === slug)).filter(isProject)
}));

const pluginPillars = [
  "Document viewing and HTML rendering inside Appian interfaces",
  "Evidence highlighting, bounding-box review, and document intelligence UX",
  "Custom component boundaries for event capture and workflow handoff",
  "Public-safe component positioning that avoids unverified implementation claims"
];
---

<BaseLayout
  title="Plugins and Accelerators"
  description={pageDescription}
  path="/plugins-and-accelerators"
  structuredData={structuredData}
>
  <section class="section-band">
    <div class="shell grid gap-8 lg:grid-cols-[0.96fr_1.04fr] lg:items-start">
      <div>
        <p class="eyebrow mb-4">Plugins and Accelerators</p>
        <h1 class="text-balance text-4xl font-semibold leading-tight text-text md:text-6xl">
          Reusable Appian assets for plugins, workflow delivery, and platform acceleration.
        </h1>
        <p class="mt-6 text-lg leading-8 text-muted">
          This page groups productized Appian component work with accelerator patterns. It shows reusable value without exposing private client implementation details.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="quiet-button" href={withBase("/work/plugins")}>Browse plugins</a>
          <a class="primary-button" href={withBase("/work/accelerators")}>Browse accelerators</a>
        </div>
      </div>

      <aside class="glass-panel p-6">
        <p class="eyebrow">Library snapshot</p>
        <dl class="mt-5 grid gap-3 sm:grid-cols-3">
          <div class="proof-tile">
            <dt>Plugins</dt>
            <dd>{pluginCards.length}</dd>
          </div>
          <div class="proof-tile">
            <dt>Accelerators</dt>
            <dd>{acceleratorWorkstreams.length}</dd>
          </div>
          <div class="proof-tile">
            <dt>Groups</dt>
            <dd>{acceleratorGroups.length}</dd>
          </div>
        </dl>
        <p class="mt-6 text-sm leading-7 text-muted">
          Accelerator details are grouped into capability families so platform, delivery, integration, and governance value is easier to scan.
        </p>
      </aside>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Plugin library" title="Custom Appian components for document-heavy and interaction-heavy workflow experiences." copy="These plugins frame Leelark as a hands-on component developer who can extend Appian when standard interface patterns are not enough." />
      <div class="mt-8 grid items-start gap-4 lg:grid-cols-[0.76fr_1.24fr]">
        <div class="rounded-portfolio border border-border bg-surface/74 p-5">
          <p class="eyebrow">Reusable plugin value</p>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-muted">
            {pluginPillars.map((pillar) => (
              <li class="flex gap-2">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                <span>{pillar}</span>
              </li>
            ))}
          </ul>
        </div>
        <ProjectExplorer projects={pluginCards} categories={categories} showFilters={false} compact client:load />
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Accelerator library" title="Reusable workstreams grouped as one advisory and delivery capability suite." copy="Repeated platform problems become reusable Appian patterns, operating-model guidance, and implementation accelerators." />
      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {acceleratorGroups.map((group, index) => (
          <article class="glass-panel p-5">
            <p class="text-xs font-bold uppercase text-accent">Group 0{index + 1}</p>
            <h2 class="mt-4 text-xl font-semibold text-text">{group.title}</h2>
            <p class="mt-3 text-sm leading-7 text-muted">{group.copy}</p>
            <ul class="mt-5 grid gap-2 text-sm leading-6 text-muted">
              {group.items.map((item) => (
                <li class="flex gap-2">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-blueSignal" aria-hidden="true"></span>
                  <span>{item.title}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
      <div class="mt-8 rounded-portfolio border border-border bg-surface/74 p-5">
        <p class="text-sm leading-7 text-muted">
          The accelerator suite is presented as a portfolio-ready library. Each workstream is framed around the reusable problem it solves, the Appian capability it strengthens, and the operating value it can create.
        </p>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Standalone accelerator spotlights" title="Platform-health accelerators with distinct architecture and operating-model stories." />
      <div class="mt-8">
        <ProjectExplorer projects={standaloneAcceleratorCards} categories={categories} showFilters={false} compact client:load />
      </div>
    </div>
  </section>
</BaseLayout>
