---
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { featuredAccelerators, projectsByCategory } from "@/lib/content";
---

<BaseLayout title="Plugins and Accelerators" description="Custom Appian plugins, document intelligence components, and reusable Appian accelerator patterns." path="/plugins-and-accelerators">
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Plugins and accelerators" title="Custom components and reusable Appian delivery patterns." copy="This section brings together plugin work, document intelligence components, dynamic grid patterns, Appian Accelerate advisory assets, and platform-health accelerators." />
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {[...projectsByCategory.plugins, ...featuredAccelerators].map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
