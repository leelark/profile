---
import { canonicalUrl, withBase } from "@/lib/paths";

const targetPath = "/key-works";
const targetUrl = withBase(targetPath);
const canonical = canonicalUrl(targetPath);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="refresh" content={`0; url=${targetUrl}`} />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonical} />
    <title>Redirecting to Key Works | Leelark Saxena</title>
    <script is:inline define:vars={{ targetUrl }}>
      window.location.replace(targetUrl);
    </script>
  </head>
  <body>
    <main>
      <p>Redirecting to <a href={targetUrl}>Key Works</a>.</p>
    </main>
  </body>
</html>
