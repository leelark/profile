---
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { expertiseAreas, experience, profile, renderedProfile } from "@/lib/content";
import { withBase } from "@/lib/paths";
import { breadcrumbStructuredData, personStructuredData, webPageStructuredData } from "@/lib/seo";

const currentRole = experience[0];
const pageDescription = profile.homepageSummary;
const structuredData = [
  personStructuredData(),
  webPageStructuredData({
    type: "ProfilePage",
    name: "About Leelark Saxena",
    description: pageDescription,
    path: "/about"
  }),
  breadcrumbStructuredData([
    { name: "Home", path: "/" },
    { name: "About", path: "/about" }
  ])
];
const workingModel = [
  {
    title: "Architecture-first discovery",
    copy: "Clarify the workflow, users, data model, integrations, controls, and evidence before committing the Appian design."
  },
  {
    title: "Hands-on delivery depth",
    copy: "Move from solution shape into SAIL, records, process models, APIs, AI skills, plugins, testing, and operational handoff."
  },
  {
    title: "Reusable enterprise patterns",
    copy: "Turn repeated client problems into accelerators, governance playbooks, platform-health reviews, and reusable UX patterns."
  }
];
---

<BaseLayout title="About" description={pageDescription} path="/about" structuredData={structuredData}>
  <section class="section-band">
    <div class="shell grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div>
        <p class="eyebrow mb-4">About Leelark Saxena</p>
        <h1 class="text-balance text-4xl font-semibold leading-tight text-text md:text-6xl">
          Enterprise Appian architect with AI, plugin, and workflow automation depth.
        </h1>
        <p class="mt-6 text-lg leading-8 text-muted">{profile.shortBio}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="primary-button" href={withBase("/work")}>View portfolio work</a>
          <a class="quiet-button" href={withBase("/contact")}>Discuss Appian work</a>
        </div>
      </div>

      <aside class="glass-panel p-6">
        <p class="eyebrow">Professional identity</p>
        <p class="mt-4 text-xl font-semibold leading-8 text-text">{profile.primaryRole}</p>
        {currentRole && (
          <div class="mt-6 rounded-portfolio border border-border bg-elevated/58 p-4">
            <p class="text-xs font-bold uppercase text-muted">Current focus</p>
            <p class="mt-2 text-base font-semibold text-text">{currentRole.role}</p>
            <p class="mt-2 text-sm leading-6 text-muted">{currentRole.positioning}</p>
          </div>
        )}
      </aside>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
      <SectionHeader eyebrow="Profile" title="I connect enterprise requirements with practical Appian architecture and usable workflow design." />
      <div class="prose-portfolio" set:html={renderedProfile.longBio} />
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Working style" title="Senior consulting, technical leadership, and product-minded delivery in one operating model." />
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {workingModel.map((item, index) => (
          <article class="purple-frame rounded-portfolio p-5">
            <p class="text-xs font-bold uppercase text-accent">0{index + 1}</p>
            <h2 class="mt-4 text-xl font-semibold text-text">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 text-muted">{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <SectionHeader eyebrow="Strengths" title="Appian architecture, workflow automation, AI design, reusable assets, and enterprise UX." />
        <div class="mt-7 grid gap-3 sm:grid-cols-2">
          {profile.strengths.map((strength) => (
            <div class="rounded-portfolio border border-border bg-surface/74 p-4 text-sm font-semibold text-text">{strength}</div>
          ))}
        </div>
      </div>
      <div>
        <SectionHeader eyebrow="Domains" title="Enterprise contexts for Appian delivery." />
        <div class="mt-7 flex flex-wrap gap-2">
          {profile.domains.map((domain) => <span class="chip">{domain}</span>)}
        </div>
        <div class="mt-6 rounded-portfolio border border-border bg-surface/72 p-5">
          <p class="text-sm leading-7 text-muted">{profile.aboutClosingCopy}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Capability map" title="Where the profile connects to evidence-backed portfolio work." />
      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {expertiseAreas.slice(0, 6).map((area) => (
          <article class="glass-panel p-5">
            <h2 class="text-xl font-semibold text-text">{area.title}</h2>
            <p class="mt-3 text-sm leading-7 text-muted">{area.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
