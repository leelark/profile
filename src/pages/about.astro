---
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { profile, renderedProfile } from "@/lib/content";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: "Enterprise Appian Solution Architect",
  url: "https://leelark.github.io/profile/"
};
---

<BaseLayout title="About" description={profile.shortBio} path="/about" structuredData={structuredData}>
  <section class="section-band">
    <div class="shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeader as="h1" eyebrow="About" title="Enterprise Appian consultant with architecture, product, AI, and plugin depth." />
      <div class="prose-portfolio" set:html={renderedProfile.longBio} />
    </div>
  </section>
  <section class="section-band border-t border-border">
    <div class="shell grid gap-4 md:grid-cols-2">
      <article class="rounded-portfolio border border-border bg-surface p-6">
        <h2 class="text-xl font-semibold text-text">Professional strengths</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {profile.strengths.map((strength) => <span class="chip">{strength}</span>)}
        </div>
      </article>
      <article class="rounded-portfolio border border-border bg-surface p-6">
        <h2 class="text-xl font-semibold text-text">Domains</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {profile.domains.map((domain) => <span class="chip">{domain}</span>)}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
