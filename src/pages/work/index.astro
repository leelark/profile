---
import ProjectExplorer from "@/components/ProjectExplorer";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categoryLabels, projectToCard, projects } from "@/lib/content";

const categories = Object.entries(categoryLabels).map(([slug, label]) => ({ slug, label }));
const cards = projects.map(projectToCard);
---

<BaseLayout title="Work" description="Explore Leelark Saxena's Appian client projects, plugins, innovative POCs, and accelerators." path="/work">
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Work" title="A modal-first portfolio of Appian architecture, AI workflows, plugins, and accelerators." copy="Use the animated tabs to move between client delivery, custom components, innovation POCs, and reusable Appian accelerators." />
      <div class="mt-10">
        <ProjectExplorer projects={cards} categories={categories} client:load />
      </div>
    </div>
  </section>
</BaseLayout>
