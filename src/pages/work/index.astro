---
import ProjectExplorer from "@/components/ProjectExplorer";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categoryLabels, portfolioProjects, projectToCard } from "@/lib/content";
import { collectionPageStructuredData } from "@/lib/seo";

const categories = Object.entries(categoryLabels).map(([slug, label]) => ({ slug, label }));
const cards = portfolioProjects.map(projectToCard);
const pageDescription = "Portfolio work across Appian client delivery, plugins, product POCs, and reusable accelerators.";
const categorySignals = [
  { title: "Client Projects", label: "Enterprise delivery" },
  { title: "Plugins", label: "Appian extension" },
  { title: "Innovative Projects", label: "AI product thinking" },
  { title: "Accelerators", label: "Appian Accelerate Program" }
];
const structuredData = collectionPageStructuredData({
  name: "Portfolio Work - Leelark Saxena",
  description: pageDescription,
  path: "/work",
  projects: portfolioProjects,
  breadcrumbs: [
    { name: "Home", path: "/" },
    { name: "Work", path: "/work" }
  ]
});
---

<BaseLayout title="Work" description={pageDescription} path="/work" structuredData={structuredData}>
  <section class="section-band">
    <div class="shell">
      <div class="work-hero-panel">
        <div>
          <SectionHeader as="h1" eyebrow="Work" title="Architecture-led work across enterprise Appian, AI workflows, plugins, and Appian Accelerate." copy="A category-driven portfolio view with less metadata, stronger visual markers, and concise project snapshots." />
        </div>
        <div class="work-category-compass" aria-label="Work categories">
          {categorySignals.map((item, index) => (
            <span>
              <i>{String(index + 1).padStart(2, "0")}</i>
              <b>{item.title}</b>
              <em>{item.label}</em>
            </span>
          ))}
        </div>
      </div>
      <div class="mt-10">
        <ProjectExplorer projects={cards} categories={categories} client:load />
      </div>
    </div>
  </section>
</BaseLayout>
