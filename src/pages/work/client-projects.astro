---
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categoryDescriptions, projectsByCategory } from "@/lib/content";
---

<BaseLayout title="Client Projects" description={categoryDescriptions["client-projects"]} path="/work/client-projects">
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Client projects" title="Enterprise Appian delivery, advisory, and workflow modernization." copy={categoryDescriptions["client-projects"]} />
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {projectsByCategory["client-projects"].map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
