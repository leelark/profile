---
import ProjectExplorer from "@/components/ProjectExplorer";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categoryDescriptions, categoryLabels, projectToCard, projectsByCategory } from "@/lib/content";

const categories = Object.entries(categoryLabels).map(([slug, label]) => ({ slug, label }));
const cards = projectsByCategory.plugins.map(projectToCard);
---

<BaseLayout title="Plugins" description={categoryDescriptions.plugins} path="/work/plugins">
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Plugins" title="Custom Appian component innovation for document and HTML-heavy workflows." copy={categoryDescriptions.plugins} />
      <div class="mt-10">
        <ProjectExplorer projects={cards} categories={categories} showFilters={false} client:load />
      </div>
    </div>
  </section>
</BaseLayout>
