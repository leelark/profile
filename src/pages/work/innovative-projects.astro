---
import ProjectCard from "@/components/ProjectCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categoryDescriptions, projectsByCategory } from "@/lib/content";
---

<BaseLayout title="Innovative Projects" description={categoryDescriptions["innovative-projects"]} path="/work/innovative-projects">
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Innovation POCs" title="AI-enabled product thinking across claims, knowledge, citizen services, and workflow automation." copy={categoryDescriptions["innovative-projects"]} />
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {projectsByCategory["innovative-projects"].map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
