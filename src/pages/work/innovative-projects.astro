---
import ProjectExplorer from "@/components/ProjectExplorer";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categoryDescriptions, categoryLabels, projectToCard, projectsByCategory } from "@/lib/content";

const categories = Object.entries(categoryLabels).map(([slug, label]) => ({ slug, label }));
const cards = projectsByCategory["innovative-projects"].map(projectToCard);
---

<BaseLayout title="Innovative Projects" description={categoryDescriptions["innovative-projects"]} path="/work/innovative-projects">
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Innovation POCs" title="AI-enabled product thinking across claims, knowledge, citizen services, and workflow automation." copy={categoryDescriptions["innovative-projects"]} />
      <div class="mt-10">
        <ProjectExplorer projects={cards} categories={categories} showFilters={false} client:load />
      </div>
    </div>
  </section>
</BaseLayout>
