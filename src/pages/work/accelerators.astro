---
import ProjectExplorer from "@/components/ProjectExplorer";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { acceleratorSuiteProjects, categoryDescriptions, categoryLabels, projectToCard, standaloneAccelerators } from "@/lib/content";
import { collectionPageStructuredData } from "@/lib/seo";

const categories = Object.entries(categoryLabels).map(([slug, label]) => ({ slug, label }));
const cards = standaloneAccelerators.map(projectToCard);
const pageDescription = categoryDescriptions.accelerators;
const structuredData = collectionPageStructuredData({
  name: "Appian Accelerators - Leelark Saxena",
  description: pageDescription,
  path: "/work/accelerators",
  projects: standaloneAccelerators,
  breadcrumbs: [
    { name: "Home", path: "/" },
    { name: "Work", path: "/work" },
    { name: "Accelerators", path: "/work/accelerators" }
  ]
});
const suiteGroups = [
  "Enterprise UX and data entry",
  "Excel, document, and file automation",
  "Platform health and observability",
  "Integration reliability",
  "Governance and operating model",
  "AI and process intelligence"
];
---

<BaseLayout title="Accelerators" description={pageDescription} path="/work/accelerators" structuredData={structuredData}>
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Accelerators" title="The accelerator library is grouped under the Appian Accelerate Program." copy="Most accelerator workstreams are presented as one advisory capability suite. Key standalone workstreams remain visible below because they carry distinct architecture and platform-depth stories." />
      <div class="mt-8 grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
        <article class="glass-panel p-6">
          <p class="eyebrow">Umbrella program</p>
          <h2 class="mt-3 text-2xl font-semibold text-text">Appian Accelerate accelerator suite</h2>
          <p class="mt-4 text-sm leading-7 text-muted">
            {acceleratorSuiteProjects.length} reusable workstreams are consolidated into the Appian Accelerate case study, covering UX patterns, Excel and document automation, governance, integration reliability, observability, AI enablement, and transition automation.
          </p>
        </article>
        <div class="grid gap-3 sm:grid-cols-2">
          {suiteGroups.map((group) => (
            <div class="rounded-portfolio border border-border bg-surface/72 p-4">
              <p class="text-sm font-semibold text-text">{group}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="mt-10">
        <ProjectExplorer projects={cards} categories={categories} showFilters={false} client:load />
      </div>
    </div>
  </section>
</BaseLayout>
