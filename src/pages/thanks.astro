---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
---

<BaseLayout title="Thanks" description="Thank you for contacting Leelark Saxena." path="/thanks" noindex>
  <section class="section-band">
    <div class="shell">
      <div class="mx-auto max-w-reading rounded-portfolio border border-border bg-surface p-8 text-center">
        <p class="eyebrow mb-4">Message received</p>
        <h1 class="text-4xl font-semibold text-text">Thanks for reaching out.</h1>
        <p class="mt-5 text-muted">I will review your message and respond through the contact details provided.</p>
        <a class="mt-8 inline-flex min-h-12 items-center rounded-portfolio bg-accent px-5 text-sm font-bold text-white" href={withBase("/")}>Return home</a>
      </div>
    </div>
  </section>
</BaseLayout>
