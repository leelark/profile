---
import SectionHeader from "@/components/SectionHeader.astro";
import TechnicalSkillGrid from "@/components/TechnicalSkillGrid";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { expertiseAreas, technicalSkillGroups } from "@/lib/content";
import { breadcrumbStructuredData, personStructuredData, webPageStructuredData } from "@/lib/seo";

const pageDescription = "Appian solution design, workflow automation, plugin engineering, data integration, and platform governance expertise.";
const structuredData = [
  personStructuredData(),
  webPageStructuredData({
    name: "Appian Expertise - Leelark Saxena",
    description: pageDescription,
    path: "/expertise"
  }),
  breadcrumbStructuredData([
    { name: "Home", path: "/" },
    { name: "Expertise", path: "/expertise" }
  ])
];
const lifecycle = [
  ["Discover", "process pain points, users, systems, documents"],
  ["Solution Design", "workflow, data, controls, integration model"],
  ["Build", "SAIL, records, process models, plugins, APIs"],
  ["Integrate", "SQL, SFTP, web APIs, document flows"],
  ["Validate", "testing, security, performance, accessibility"],
  ["Scale", "governance, monitoring, accelerators, optimization"]
];
---

<BaseLayout title="Expertise" description={pageDescription} path="/expertise" structuredData={structuredData}>
  <section class="section-band">
    <div class="shell">
      <SectionHeader as="h1" eyebrow="Expertise" title="Solution design across the complete Appian delivery lifecycle." copy="I work from discovery to build, integration, validation, and platform scale. The focus is practical delivery, not tool lists." />

      <div class="mt-10 grid gap-3 md:grid-cols-3 lg:grid-cols-6">
        {lifecycle.map(([stage, copy], index) => (
          <article class="purple-frame rounded-portfolio p-4">
            <p class="text-xs font-bold uppercase text-accent">0{index + 1}</p>
            <h2 class="mt-3 text-lg font-semibold text-text">{stage}</h2>
            <p class="mt-2 text-xs leading-5 text-muted">{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Capability lanes" title="A visual map of how the work is delivered." copy="Each lane connects business intent, Appian build depth, reusable assets, and operating controls." />
      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {expertiseAreas.map((area, index) => (
          <article class="capability-lane-card">
            <div class="capability-lane-visual" aria-hidden="true">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <div>
                <i></i>
                <i></i>
                <i></i>
              </div>
            </div>
            <h2>{area.title}</h2>
            <p>{area.summary}</p>
            <div class="mt-5 grid gap-2">
              {area.capabilities.slice(0, 4).map((capability) => <span class="capability-line">{capability}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <SectionHeader eyebrow="Technical skill map" title="Platform, programming, data, integration, and governance skills." />
      <div class="mt-8">
        <TechnicalSkillGrid groups={technicalSkillGroups} compact />
      </div>
    </div>
  </section>
</BaseLayout>
