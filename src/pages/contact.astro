---
import ContactForm from "@/components/ContactForm.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { contact } from "@/lib/content";
---

<BaseLayout title="Contact" description="Contact Leelark Saxena for Appian architecture, AI workflow, plugin, and enterprise automation work." path="/contact">
  <section class="section-band">
    <div class="shell grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div>
        <SectionHeader as="h1" eyebrow="Contact" title="Discuss Appian architecture, AI workflow automation, or plugin development." />
        <div class="mt-7 grid gap-3">
          <div class="purple-frame rounded-portfolio p-4">
            <p class="text-xs font-bold uppercase text-muted">Best fit</p>
            <p class="mt-2 text-sm leading-6 text-text">Appian consulting, solution architecture, plugin/component work, AI workflow design, and enterprise automation POCs.</p>
          </div>
          <div class="rounded-portfolio border border-border bg-surface/72 p-4">
            <p class="text-xs font-bold uppercase text-muted">Email</p>
            <a class="mt-2 block text-sm font-semibold text-text hover:text-accent" href={`mailto:${contact.email}`}>{contact.email}</a>
          </div>
        </div>
      </div>

      <div class="glass-panel p-5 md:p-6">
        <ContactForm />
        <p class="mt-5 text-xs leading-5 text-muted">
          Please avoid sharing confidential client data, credentials, tokens, or sensitive project details in this form.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
