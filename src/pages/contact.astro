---
import ContactForm from "@/components/ContactForm.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { contact } from "@/lib/content";
import { breadcrumbStructuredData, personStructuredData, webPageStructuredData } from "@/lib/seo";

const pageDescription = "Contact Leelark Saxena for Appian solution design, workflow automation, plugin engineering, and enterprise delivery work.";
const contactSignals = [
  {
    title: "Architecture",
    icon: ["M4 17L17 4", "M14 4h3v3", "M5 7h4", "M5 11h7", "M5 15h4"]
  },
  {
    title: "Automation",
    icon: ["M4 6h6v6H4z", "M14 12h6v6h-6z", "M10 9h3a3 3 0 0 1 3 3"]
  },
  {
    title: "Plugins and APIs",
    icon: ["M8 8l-4 4 4 4", "M16 8l4 4-4 4", "M11 18l2-12"]
  },
  {
    title: "Data Modeling and Integration",
    icon: ["M5 7c0-2 14-2 14 0s-14 2-14 0", "M5 7v10c0 2 14 2 14 0V7", "M5 12c0 2 14 2 14 0"]
  }
];
const structuredData = [
  personStructuredData(),
  webPageStructuredData({
    type: "ContactPage",
    name: "Contact Leelark Saxena",
    description: pageDescription,
    path: "/contact"
  }),
  breadcrumbStructuredData([
    { name: "Home", path: "/" },
    { name: "Contact", path: "/contact" }
  ])
];
---

<BaseLayout title="Contact" description={pageDescription} path="/contact" structuredData={structuredData}>
  <section class="section-band contact-page-section">
    <div class="shell contact-page-shell">
      <div class="contact-page-header" data-reveal="text">
        <SectionHeader as="h1" eyebrow="Contact" title="Discuss Appian solution design and delivery." />
      </div>

      <div class="contact-page-grid">
        <div class="contact-info-column" data-reveal="section" style="--reveal-delay: 70ms">
          <div class="contact-detail-grid" data-reveal-group>
            <div class="contact-detail-card">
              <p class="text-xs font-bold uppercase text-muted">Email</p>
              <a class="mt-2 block text-sm font-semibold text-text hover:text-accent" href={`mailto:${contact.email}`}>{contact.email}</a>
            </div>
            <div class="contact-detail-card">
              <p class="text-xs font-bold uppercase text-muted">Location</p>
              <p class="mt-2 text-sm font-semibold text-text">{contact.location}</p>
            </div>
            <div class="contact-topic-flow" aria-label="Contact focus areas">
              <div class="contact-flow-head">
                <p>Good fit for</p>
              </div>
              <ul class="contact-flow-list">
                {contactSignals.map((signal) => (
                  <li>
                    <span class="contact-flow-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none">
                        {signal.icon.map((path) => <path d={path} />)}
                      </svg>
                    </span>
                    <strong>{signal.title}</strong>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <div class="glass-panel contact-form-panel p-5 md:p-6" data-reveal="panel" style="--reveal-delay: 130ms">
          <ContactForm />
          <p class="mt-5 text-xs leading-5 text-muted">
            Please avoid sharing confidential client data, credentials, tokens, or sensitive project details in this form.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
