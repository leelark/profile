---
import HeroVisual from "@/components/HeroVisual.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TechnicalSkillGrid from "@/components/TechnicalSkillGrid";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BadgeCheck, BrainCircuit, ExternalLink, FileText, Gauge, Layers3, Newspaper, SearchCheck, Workflow } from "lucide-react";
import {
  appianCapabilityShowcase,
  certifications,
  clientShowcase,
  publication,
  technicalSkillGroups
} from "@/lib/content";
import { withBase } from "@/lib/paths";
import { personStructuredData, websiteStructuredData } from "@/lib/seo";

const structuredData = [personStructuredData(), websiteStructuredData()];

const heroSummary =
  "I lead requirements analysis, solution design, Appian delivery, AI-assisted workflow design, and integrations that connect users, data, records, documents, and enterprise systems.";
const heroRoles = [
  { label: "Solution Architect", tone: "blue" },
  { label: "Lead Appian Developer", tone: "green" },
  { label: "Senior Appian Consultant", tone: "amber" }
];
const operatingLayers = [
  {
    title: "Requirement Analysis",
    icon: SearchCheck,
    tone: "blue",
    signal: "Scope"
  },
  {
    title: "Solution Blueprint",
    icon: Layers3,
    tone: "teal",
    signal: "Design"
  },
  {
    title: "Lead Appian Build",
    icon: Workflow,
    tone: "green",
    signal: "Delivery"
  },
  {
    title: "AI + Integration Design",
    icon: BrainCircuit,
    tone: "amber",
    signal: "Connect"
  },
  {
    title: "Release Confidence",
    icon: BadgeCheck,
    tone: "blue",
    signal: "Validate"
  },
  {
    title: "Continuous Improvement",
    icon: Gauge,
    tone: "neutral",
    signal: "Operate"
  }
];
const clientCards = clientShowcase.map((client) => {
  const metadata: Record<string, { initials: string; logoUrl: string; color: string; color2: string }> = {
    Invesco: {
      initials: "IV",
      logoUrl: "https://www.invesco.com/etc.clientlibs/invesco/clientlibs/main/resources/images/apple-touch-icon.png",
      color: "33 93 214",
      color2: "91 171 255"
    },
    Carlyle: {
      initials: "CL",
      logoUrl: "https://www.carlyle.com/themes/carlyle_2026/resources/images/favicon/Carlyle-Favicon-96x96.png",
      color: "93 168 216",
      color2: "178 103 239"
    },
    HSBC: {
      initials: "HS",
      logoUrl: "https://www.hsbc.com/apple-touch-icon-precomposed.png",
      color: "219 0 17",
      color2: "250 204 21"
    },
    KPMG: {
      initials: "KP",
      logoUrl: "https://kpmg.com/etc.clientlibs/kpmg/clientlibs/clientlib-site/resources/images/favicons/apple-touch-icon-152x152.png",
      color: "0 51 160",
      color2: "91 171 255"
    },
    EBRD: {
      initials: "EB",
      logoUrl: "https://www.ebrd.com/etc.clientlibs/ebrd_dxp/clientlibs/clientlib-site/resources/images/favicon.ico",
      color: "0 156 110",
      color2: "52 211 153"
    },
    Genpact: {
      initials: "GP",
      logoUrl: "https://www.genpact.com/etc.clientlibs/genpact/clientlibs/clientlib-site/resources/icon-192x192.png",
      color: "255 140 47",
      color2: "91 171 255"
    }
  };

  return {
    name: client,
    ...(metadata[client] ?? {
      initials: client.slice(0, 2).toUpperCase(),
      logoUrl: "",
      color: "91 171 255",
      color2: "52 211 153"
    })
  };
});
const domainCards = [
  { title: "Banking", code: "BK", focus: ["Regulatory workflow", "Auditability"] },
  { title: "Investment Management", code: "IM", focus: ["AML", "Reconciliation"] },
  { title: "Insurance", code: "IN", focus: ["Claims", "Evidence review"] },
  { title: "Healthcare", code: "HC", focus: ["Documents", "Revenue cycle"] },
  { title: "Manufacturing", code: "MF", focus: ["Traceability", "Exceptions"] },
  { title: "Enterprise Advisory", code: "EA", focus: ["Governance", "Platform health"] },
  { title: "Public-Sector POCs", code: "PS", focus: ["Citizen journeys", "Eligibility"] }
];
---

<BaseLayout title="Leelark Saxena - Appian Solution Architect and Developer" description={heroSummary} path="/" structuredData={structuredData}>
  <section class="section-band hero-section pt-10 md:pt-14">
    <div class="shell grid gap-9 lg:grid-cols-[1.12fr_0.88fr] lg:items-center">
      <div class="max-w-3xl" data-reveal="text" style="--reveal-delay: 35ms">
        <p class="eyebrow mb-4">Enterprise Appian Architecture</p>
        <h1 class="text-balance text-4xl font-semibold leading-[1.04] text-text md:text-6xl">
          Leelark Saxena
        </h1>
        <p class="hero-positioning-line mt-5 text-balance text-2xl font-semibold leading-tight text-text/94 md:text-3xl">
          <span>Solution Architect</span> for enterprise Appian workflows, AI-assisted delivery, and integration-led platforms.
        </p>
        <div class="hero-role-line mt-5" role="group" aria-label={`Focused as ${heroRoles.map((role) => role.label).join(", ")}`}>
          <span class="hero-role-label">Focused as</span>
          <span class="hero-role-rotator" data-hero-role-rotator data-roles={JSON.stringify(heroRoles)} aria-hidden="true">
            <span class:list={["hero-role-value", `hero-role-value-${heroRoles[0].tone}`]}>
              {heroRoles[0].label}
            </span>
          </span>
        </div>
        <p class="mt-6 max-w-2xl text-base leading-8 text-muted md:text-lg">
          {heroSummary}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="primary-button" href={withBase("/work")}>Explore work</a>
          <a class="quiet-button" href={withBase("/contact")}>Start a conversation</a>
        </div>
      </div>
      <div data-reveal="media" style="--reveal-delay: 130ms">
        <HeroVisual />
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div data-reveal="text">
        <SectionHeader
          eyebrow="Delivery contribution"
          title="A clearer path from Appian idea to governed release."
          copy="A compact operating model for Appian work: scope the process, blueprint the solution, lead the build, connect AI and integrations, validate readiness, and improve after launch."
        />
      </div>
      <div class="operating-model mt-8" data-operating-model data-reveal="panel" style="--reveal-delay: 90ms" aria-label="What I bring to Appian programs">
        <div class="operating-model-header" aria-hidden="true">
          <span>Process control board</span>
          <b>Scope to release</b>
        </div>
        <div class="operating-model-stage">
          <div class="operating-flow" aria-label="Delivery contribution flow">
            <span class="operating-flow-track" aria-hidden="true"></span>
            <div class="operating-flow-core" aria-hidden="true">
              <span class="operating-flow-core-ring"></span>
              <span class="operating-flow-core-icon">
                <Workflow size={22} strokeWidth={2.2} />
              </span>
              <strong>Appian</strong>
              <b>Delivery Core</b>
              <em>Scope | Build | Govern</em>
            </div>
            {operatingLayers.map((layer, index) => {
              const Icon = layer.icon;
              return (
                <article
                  class:list={[
                    "operating-flow-node",
                    {
                      "operating-flow-node-blue": layer.tone === "blue",
                      "operating-flow-node-teal": layer.tone === "teal",
                      "operating-flow-node-green": layer.tone === "green",
                      "operating-flow-node-amber": layer.tone === "amber",
                      "operating-flow-node-neutral": layer.tone === "neutral"
                    }
                  ]}
                  style={`--step-index: ${index}`}
                >
                  <span class="operating-flow-icon">
                    <Icon size={18} strokeWidth={2.25} aria-hidden="true" />
                  </span>
                  <span class="operating-flow-copy">
                    <strong>{layer.title}</strong>
                    <b>{layer.signal}</b>
                  </span>
                  <span class="operating-flow-geometry" aria-hidden="true"></span>
                </article>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="technical-skills" class="section-band border-t border-border">
    <div class="shell">
      <div>
        <div data-reveal="text">
          <SectionHeader eyebrow="Technical skills" title="Appian technical depth for delivery." copy="Focused skills across solution design, lead development, database delivery, AI workflows, testing, and governance." />
        </div>
        <div class="mt-8" data-reveal="section" style="--reveal-delay: 90ms">
          <TechnicalSkillGrid groups={technicalSkillGroups} appianCapabilities={appianCapabilityShowcase} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-band credential-section border-t border-border">
    <div class="shell">
      <div data-reveal="text">
        <SectionHeader eyebrow="Credentials" title="Certification and research foundation." />
      </div>
      <div class="credential-stage mt-8" data-reveal-group style="--reveal-delay: 90ms">
        <article class="credential-card credential-card-certifications">
          <h2 class="text-xl font-semibold text-text">Certifications</h2>
          <div class="mt-4 space-y-3">
            {certifications.map((item) => (
              <div class="credential-row">
                <p class="text-sm font-semibold text-text">{item.title}</p>
                {item.score && <p class="mt-1 text-xs font-bold text-accent">{item.score}</p>}
              </div>
            ))}
          </div>
        </article>
        <article class="credential-card credential-card-publication">
          <div class="publication-card-head">
            <span class="publication-card-mark" aria-hidden="true">
              <Newspaper size={22} strokeWidth={2.2} />
            </span>
            <div>
              <p class="publication-eyebrow">Research Publication</p>
              <h2>Modern web application security research</h2>
            </div>
          </div>
          <div class="publication-paper">
            <span aria-hidden="true"><FileText size={18} strokeWidth={2.2} /></span>
            <p>{publication.title}</p>
          </div>
          <p class="publication-summary">{publication.websiteCopy}</p>
          <a class="publication-link" href={publication.url} target="_blank" rel="noreferrer">
            View publication
            <ExternalLink size={14} strokeWidth={2.2} aria-hidden="true" />
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band border-t border-border">
    <div class="shell">
      <div data-reveal="text">
        <SectionHeader eyebrow="Domains" title="Enterprise contexts where Appian delivery patterns apply." />
      </div>
      <div class="domain-constellation mt-8" data-reveal-group style="--reveal-delay: 90ms">
        {domainCards.map((domain) => (
          <article class="domain-card">
            <span>{domain.code}</span>
            <h2>{domain.title}</h2>
            <div>
              {domain.focus.map((item) => <i>{item}</i>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="enterprise-delivery-footprint" class="section-band client-showcase-section border-t border-border">
    <div class="shell">
      <div data-reveal="text">
        <SectionHeader eyebrow="Enterprise client experience" title="Appian delivery across respected organizations." copy="A public-safe snapshot of enterprise teams and programs where I contributed to Appian solution design, workflow delivery, and execution support." />
      </div>
      <div class="client-marquee mt-8" data-reveal="section" style="--reveal-delay: 90ms" aria-label="Enterprise client experience">
        <div class="client-marquee-track">
          {[...clientCards, ...clientCards].map((client) => (
            <article style={`--client-color: ${client.color}; --client-color-2: ${client.color2};`}>
              <span class="client-logo-mark" aria-hidden="true">
                {client.logoUrl && <img src={client.logoUrl} alt="" loading="lazy" decoding="async" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />}
                <b class="client-logo-fallback">{client.initials}</b>
              </span>
              <div class="client-card-copy">
                <h2>{client.name}</h2>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="next-conversation" class="section-band border-t border-border">
    <div class="shell">
      <div class="contact-cta-band" data-reveal="panel">
        <div class="contact-cta-copy">
          <p class="eyebrow">Next conversation</p>
          <h2>Bring clarity to your next Appian delivery.</h2>
          <p>For teams that need clearer workflows, stronger delivery rhythm, AI-assisted automation, or Appian accelerator support.</p>
        </div>
        <div class="contact-cta-actions">
          <a class="primary-button" href={withBase("/contact")}>Start a conversation</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const roleRotators = document.querySelectorAll("[data-hero-role-rotator]");
    const reduceRoleMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    roleRotators.forEach((rotator) => {
      const rawRoles = rotator.getAttribute("data-roles");
      const valueNode = rotator.querySelector(".hero-role-value");

      if (!rawRoles || !valueNode || reduceRoleMotion) {
        return;
      }

      let roles = [];
      try {
        roles = JSON.parse(rawRoles);
      } catch {
        return;
      }

    if (!Array.isArray(roles) || roles.length < 2) {
      return;
    }

    const existingTimer = Number(rotator.getAttribute("data-role-rotator-timer"));
    if (existingTimer) {
      window.clearInterval(existingTimer);
    }

    let activeRoleIndex = Math.max(
      0,
      roles.findIndex((role) => role?.label === valueNode.textContent?.trim())
    );

    const roleTimer = window.setInterval(() => {
      rotator.classList.add("is-changing");

      window.setTimeout(() => {
          activeRoleIndex = (activeRoleIndex + 1) % roles.length;
          const nextRole = roles[activeRoleIndex];

          if (!nextRole?.label || !nextRole?.tone) {
            rotator.classList.remove("is-changing");
            return;
          }

          valueNode.textContent = nextRole.label;
        valueNode.className = `hero-role-value hero-role-value-${nextRole.tone}`;
        rotator.classList.remove("is-changing");
      }, 180);
    }, 2600);

    rotator.setAttribute("data-role-rotator-timer", String(roleTimer));
  });

</script>
</BaseLayout>
